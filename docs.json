{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Taskrit Documentation",
  "colors": {
    "primary": "#3815eb",
    "light": "#8784ec",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/minoza-ai"
    }
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "all"
  },
  "errors": {
    "404": {
      "redirect": false
    }
  },
  "description": "2026 육군창업경진대회",
  "appearance": {
    "default": "system"
  },
  "banner": {
    "dismissible": false,
    "content": "현재 개발중인 페이지입니다."
  },
  "styling": {
    "latex": true
  },
  "fonts": {
    "family": "Poppins"
  },
  "background": {
    "color": {
      "light": "#f9f9f9",
      "dark": "#060606"
    }
  }
}
