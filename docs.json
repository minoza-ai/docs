{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Taskrit Documentation",
  "colors": {
    "primary": "#3815eb",
    "light": "#8784ec",
    "dark": "#15803D"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "프로젝트 가이드",
        "icon": "book",
        "pages": [
          "index",
          "quickstart",
          "development"
        ]
      },
      {
        "tab": "API 레퍼런스",
        "icon": "network-wired",
        "groups": [
          {
            "group": "도입",
            "expanded": true,
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "엔드포인트",
            "expanded": true,
            "openapi": "api-reference/openapi.json"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/minoza-ai"
    }
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "all"
  },
  "errors": {
    "404": {
      "redirect": false
    }
  },
  "description": "2026 육군창업경진대회",
  "appearance": {
    "default": "system"
  },
  "banner": {
    "dismissible": true,
    "content": "현재 개발중인 페이지입니다."
  },
  "styling": {
    "latex": true,
    "eyebrows": "breadcrumbs"
  },
  "fonts": {
    "family": "Poppins"
  },
  "background": {
    "color": {
      "light": "#f9f9f9",
      "dark": "#060606"
    },
    "decoration": "gradient"
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  }
}
